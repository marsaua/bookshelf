<div class="flex justify-between items-center w-full p-4" style="border-bottom: 2px solid black;">
  <%= render "common/user", user: friendship.user %>
  <div class="flex flex-col gap-2">
    <%= link_to "Accept", friendship_path(friendship), data: { turbo_method: :patch }, class:"button button-primary" %>
    <%= link_to "Reject", friendship_path(friendship), data: { turbo_method: :delete }, class:"button button-secondary" %>
  </div>
</div>