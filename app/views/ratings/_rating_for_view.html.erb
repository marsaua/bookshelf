<div class="flex gap-1 items-center">
  <% average = book.average_rating.to_f %>
  <% (1..5).each do |star| %>
    <% if star <= average.floor %>
      <span class="text-2xl text-yellow-400">★</span>
    <% elsif star == average.ceil && average % 1 >= 0.5 %>
      <span class="text-2xl" style="background: linear-gradient(to right, #facc15 50%, #d1d5db 50%); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">★</span>
    <% else %>
      <span class="text-2xl text-gray-300">★</span>
    <% end %>
  <% end %>
  <span class="ml-2 text-gray-500"><%= book.average_rating || 'No ratings' %></span>
</div>