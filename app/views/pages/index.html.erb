<div class="flex flex-col gap-8 align-center">
  <h1 class="heading-h1 text-center">Your Bookshelf</h1>
  <p class="text-center">Your personal book tracker. Add books from your collection, keep track of what you've lent to friends, and never lose a book again.</p>
  <hr class="border-gray-200">

    <% if user_signed_in? %>

    <section>
      <h3 class="heading-h3 text-center py-4">Books Added Recently</h3>
      <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css"/>
      <script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>

      <div class="swiper">
        <div class="swiper-wrapper">
          <% @books.each do |book| %>
            <div class="swiper-slide">
              <%= render 'books/book', book: book, user: book.user %>
            </div>
          <% end %>
        </div>
        <div class="swiper-pagination mt-6"></div>
      </div>

      <h3 class="heading-h3 text-center py-4">Best Books</h3>

      <div class="swiper">
        <div class="swiper-wrapper">
          <% @best_books.each do |book| %>
            <div class="swiper-slide">
              <%= render 'books/book', book: book, user: book.user %>
            </div>
          <% end %>
        </div>
        <div class="swiper-pagination mt-6"></div>
      </div>

      </div>
    </section>

      <script>
        new Swiper('.swiper', {
          slidesPerView: 4,
          spaceBetween: 3,
          autoplay: {
            delay: 3000,
          },
          loop: true,
          pagination: { el: '.swiper-pagination' },
        });
      </script>
      <style>
        .swiper-pagination {
          position: relative;
          margin-top: 12px;
        }
      </style>
    <% else %>
      <div class="flex gap-2 justify-center">
          <%= link_to "Sign in", user_session_path, class:"button button-primary" %>
          <%= link_to "Sign up", new_user_registration_path, class:"button button-secondary" %>
      </div>
    <% end %>
