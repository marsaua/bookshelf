<div class="flex flex-col gap-8 align-center absolute top-[50%] left-[50%] -translate-x-1/2 -translate-y-1/2">
<h1 class="heading-h1 text-center">Your Bookshelf</h1>
<p class="text-center">Your personal book tracker. Add books from your collection, keep track of what you've lent to friends, and never lose a book again.</p>
<% if user_signed_in? %>
  <%= link_to "Sign out", destroy_user_session_path, method: :delete %>
<% else %>
    <div class="flex gap-2 justify-center">
        <%= link_to "Sign in", user_session_path, class:"button button-primary" %>
        <%= link_to "Sign up", new_user_registration_path, class:"button button-secondary" %>
    </div>
<% end %>

<%= link_to "My Books", books_path %>
</div>