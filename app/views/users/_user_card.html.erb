<div class="user-card justify-between items-start md:items-center flex-col md:flex-row ">
    <div class="flex gap-4 items-center">
        <div class="avatar">
            <% if user.avatar.present? && user.avatar != "" %>
                <%= image_tag user.avatar %>
            <% else %>
                <%= image_tag "default-avatar.jpg" %>
            <% end %>
        </div>
        <div>
            <p class="font-bold"> <%= user.first_name %> <%= user.last_name %> </p>
            <p> Interests will be soon </p>
        </div>
    </div>
    <div>
        <% friendship = Friendship.between(current_user, user).first %>
        <% if friendship %>
        <% if friendship.accepted? %>
            <%= button_to "Remove from friends", friendship_path(friendship), method: :delete, class: "color-red-700" %>
        <% elsif friendship.pending? %>
            <%= button_to "Cancel the request", friendship_path(friendship), method: :delete, class: "color-red-700" %>
        <% end %>
        <% else %>
        <%= button_to "Become friends", friendships_path, params: { friend_id: user.id }, method: :post, class: "text-[#2E6F40]" %>
        <% end %>
    </div>
</div>