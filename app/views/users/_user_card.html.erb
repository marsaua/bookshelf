<% friendship = Friendship.between(current_user, user).first %>
<div class="user-card justify-between items-center flex-col xs:flex-row">
  <%= link_to user_path(user), class: "flex gap-4 items-center flex-1 no-underline" do %>
    <div class="user-avatar">
      <% if user.avatar.attached? %>
        <%= image_tag url_for(user.avatar) %>
      <% else %>
        <%= image_tag "default-avatar.jpg" %>
      <% end %>
    </div>
    <div>
      <p class="font-bold"><%= user.first_name %> <%= user.last_name %></p>
      <% if friendship&.accepted? %>
        <span class="text-sm font-medium text-green-700">Your friend</span>
      <% elsif friendship&.pending? %>
        <span class="text-sm font-medium text-yellow-700">Request sent</span>
      <% end %>
    </div>
  <% end %>

  <div class="flex gap-2 flex-wrap items-center">
    <% if friendship&.accepted? %>
      <div class="flex gap-2 flex-col md:flex-row ">
        <%= link_to "View Books", user_books_path(user), class: "button button-primary" %>
        <%= link_to "Unfriend", friendship_path(friendship), data: { turbo_method: :delete }, class: "button button-secondary" %>
      </div>
    <% elsif friendship&.pending? %>
      <% if friendship.user == current_user %>
        <%= link_to "Cancel", friendship_path(friendship), data: { turbo_method: :delete }, class: "button button-secondary" %>
      <% else %>
        <span class="text-sm font-medium text-yellow-700">Wants to connect</span>
        <div class="flex gap-2 flex-col md:flex-row ">
          <%= link_to "Accept", friendship_path(friendship), data: { turbo_method: :patch }, class: "button button-primary" %>
          <%= link_to "Reject", friendship_path(friendship), data: { turbo_method: :delete }, class: "button button-secondary" %>
        </div>
      <% end %>
    <% else %>
      <%= button_to "Add Friend", friendships_path, params: { friend_id: user.id }, method: :post, class: "button button-primary" %>
    <% end %>
  </div>
</div>
