<section>
    <div class="shelf-container ">
        <div class="shelf-surface pb-0">
            <% if books.any? %>
                <div class="books-row">
                    <% books.each do |book| %>
                        <%= render 'books/book', book: book, user: @user %>
                    <% end %>
                </div>
            <% else %>
                <p class="text-[#a08060] italic text-center py-8">No books yet.</p>
            <% end %>
        </div>
    </div>
</section>