<div class="w-full flex flex-col md:flex-row">

<header class="flex justify-between gap-4 flex-col md:flex-row header-desktop w-full md:w-[30%] md:min-h-screen p-6 md:border-0 wood-panel--right ">
  <div class="flex flex-col gap-4">
    <%= render "books/select_by_categories" %>
  </div>
</header>
  
  <div class="w-full p-6 flex flex-col gap-6">
    <h1 class="text-3xl font-bold text-[#3b2a1a]">My Bookshelf</h1>
    <%= link_to "+ Add Book", new_book_path, class: "button button-primary" %>
    <%= render "books/books_list", books: @my_books, user: nil %>

    <%= render "lent_books/index"%>
  </div>
</div>
