<div class="w-full flex flex-col gap-12">

  <!-- Header -->
  <header class="flex items-center justify-between">
    <h1 class="text-3xl font-bold text-[#3b2a1a]">My Bookshelf</h1>
    <div class="flex items-center gap-4">
      <%= link_to "+ Add Book", new_book_path, class: "button button-primary" %>
    </div>
    

  </header>

  <!-- My Books -->

  <%= render "books/books_list", books: @my_books, user: nil %>

  <section>
    <div class="flex items-center gap-3 mb-4">
      <span class="text-2xl">🤝</span>
      <h2 class="text-lg text-[#7a5c3a]">Lent to Friend</h2>
      <span class="bg-[#d4a96a] text-[#3b2a1a] rounded-full w-6 h-6 flex items-center justify-center text-xs font-sans"><%= @lent_books.count %></span>
    </div>
    <div class="shelf-container max-w-2xl">
      <div class="shelf-surface shelf-surface--small p-4 pb-0">
        <% if @lent_books.any? %>
          <div class="books-row">
            <% @lent_books.each do |book| %>
              <%= render 'books/book', book: book, user: nil %>
            <% end %>
          </div>
        <% else %>
          <p class="text-[#a08060] italic text-center py-6 text-sm">Nothing lent out yet.</p>
        <% end %>
      </div>
    </div>
  </section>

</div>
