<div class="flex flex-col gap-8 align-center absolute top-[50%] left-[50%] -translate-x-1/2 -translate-y-1/2">
  <div class="form-backgroung">

    <h2 class="heading-h2">Forgot your password?</h2>

    <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <div class="field">
        <p><%= f.label :email %></p>
        <p><%= f.email_field :email, autofocus: true, autocomplete: "email" %></p>
      </div>

      <div class="actions">
        <%= f.submit "Send me reset instructions", class: "button button-primary" %>
      </div>
    <% end %>

    <%= render "devise/shared/links" %>
  </div>
</div>
